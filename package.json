{
  "name": "spark",
  "version": "1.0.0",
  "description": "The Electron test runner",
  "main": "lib/main.js",
  "type": "module",
  "bin": {
    "spark": "./bin/spark.cjs"
  },
  "scripts": {
    "lint": "eslint eslint.config.js bin lib test",
    "test": "npm run test:unit && npm run test:cli",
    "test:unit": "electron --no-sandbox . test/main/**/*.test.js -r test/renderer/**/*.test.js",
    "test:cli": "node --test test/cli.test.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inukshuk/spark.git"
  },
  "keywords": [
    "electron",
    "test",
    "testing",
    "coverage"
  ],
  "author": "Sylvester Keil <sylvester@keil.or.at>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/inukshuk/spark/issues"
  },
  "homepage": "https://github.com/inukshuk/spark#readme",
  "engines": {
    "node": ">=24"
  },
  "peerDependencies": {
    "electron": ">=40"
  },
  "peerDependenciesMeta": {
    "electron": { "optional": true }
  },
  "devDependencies": {
    "electron": "^41.0.2",
    "eslint": "^9.5.0",
    "neostandard": "^0.13.0"
  }
}
